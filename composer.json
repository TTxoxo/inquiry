{
  "name": "inquiry/project",
  "description": "Inquiry project stage-1 bootstrap",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.3"
  },
  "autoload": {
    "psr-4": {
      "app\\": "app/",
      "think\\": "app/common/think/"
    },
    "files": [
      "app/common/helper.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
